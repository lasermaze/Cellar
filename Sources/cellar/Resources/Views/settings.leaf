#extend("base"):
  #export("content"):
    <section>
      <h2>Settings</h2>

      <div class="section-card">
        <header>API Keys</header>
        <form method="post" action="/settings/keys">
          <div class="form-group">
            <label for="aiProvider">AI Provider</label>
            <select name="aiProvider" id="aiProvider">
              <option value="" #if(aiProvider == ""):selected#endif>Auto-detect</option>
              <option value="claude" #if(aiProvider == "claude"):selected#endif>Claude (Anthropic)</option>
              <option value="deepseek" #if(aiProvider == "deepseek"):selected#endif>Deepseek</option>
            </select>
            <div class="form-hint">Auto-detect uses whichever API key is configured. Takes effect on next launch.</div>
          </div>

          <div class="form-group">
            <label for="anthropicKey">
              Anthropic API Key
              #if(hasAnthropicKey):
                <span style="color: var(--success);"> (configured)</span>
              #endif
            </label>
            <input
              type="password"
              id="anthropicKey"
              name="anthropicKey"
              placeholder="#if(hasAnthropicKey): #(anthropicKey) #else: sk-ant-... #endif"
              autocomplete="off"
            >
          </div>

          <div class="form-group">
            <label for="openaiKey">
              OpenAI API Key
              #if(hasOpenaiKey):
                <span style="color: var(--success);"> (configured)</span>
              #endif
            </label>
            <input
              type="password"
              id="openaiKey"
              name="openaiKey"
              placeholder="#if(hasOpenaiKey): #(openaiKey) #else: sk-... #endif"
              autocomplete="off"
            >
          </div>

          <div class="form-group">
            <label for="deepseekKey">
              Deepseek API Key
              #if(hasDeepseekKey):
                <span style="color: var(--success);"> (configured)</span>
              #endif
            </label>
            <input
              type="password"
              id="deepseekKey"
              name="deepseekKey"
              placeholder="#if(hasDeepseekKey): #(deepseekKey) #else: sk-... #endif"
              autocomplete="off"
            >
          </div>

          <div class="form-hint" style="margin-bottom: 1rem;">Leave a field empty to keep the current key.</div>
          <button type="submit" class="btn btn-primary">Save Keys</button>
        </form>
      </div>

      <div class="section-card">
        <header>Community</header>
        <form method="post" action="/settings/config">
          <input type="hidden" name="contributeMemory" value="false">
          <div class="form-group">
            <label style="display: flex; align-items: center; color: var(--text);">
              <input
                type="checkbox"
                name="contributeMemory"
                value="true"
                #if(contributeMemory): checked #endif
              >
              Share working configs with the Cellar community
            </label>
            <div class="form-hint">When enabled, successfully verified game configs are automatically shared to help other users.</div>
          </div>
          <button type="submit" class="btn btn-primary">Save</button>
        </form>

        #if(contributeMemory):
          #if(successCount > 0):
            <form method="post" action="/settings/sync" style="margin-top: 1.25rem; padding-top: 1.25rem; border-top: 1px solid var(--border);">
              <button type="submit" class="btn btn-secondary">Sync #(successCount) record(s) to collective memory</button>
              <div class="form-hint" style="margin-top: 0.5rem;">Push all local success records to collective memory.</div>
            </form>
            #if(syncResult != ""):
              <div style="color: var(--success); font-size: 0.85rem; margin-top: 0.5rem;">#(syncResult)</div>
            #endif
          #endif
        #endif
      </div>
    </section>
  #endexport
#endextend
