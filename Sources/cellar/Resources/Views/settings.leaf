#extend("base"):
  #export("content"):
    <section>
      <h2>Settings</h2>

      <article>
        <header><strong>API Keys</strong></header>
        <form method="post" action="/settings/keys">
          <label for="aiProvider">
            AI Provider
          </label>
          <select name="aiProvider" id="aiProvider">
            <option value="" #if(aiProvider == ""):selected#endif>Auto-detect</option>
            <option value="claude" #if(aiProvider == "claude"):selected#endif>Claude (Anthropic)</option>
            <option value="deepseek" #if(aiProvider == "deepseek"):selected#endif>Deepseek</option>
          </select>
          <small style="color: var(--pico-muted-color);">Auto-detect uses whichever API key is configured. Takes effect on next launch.</small>

          <label for="anthropicKey">
            Anthropic API Key
            #if(hasAnthropicKey):
              <small style="color: var(--pico-ins-color);"> (configured)</small>
            #else:
              <small style="color: var(--pico-muted-color);"> (not set)</small>
            #endif
          </label>
          <input
            type="password"
            id="anthropicKey"
            name="anthropicKey"
            placeholder="#if(hasAnthropicKey): #(anthropicKey) #else: sk-ant-... #endif"
            autocomplete="off"
          >

          <label for="openaiKey">
            OpenAI API Key
            #if(hasOpenaiKey):
              <small style="color: var(--pico-ins-color);"> (configured)</small>
            #else:
              <small style="color: var(--pico-muted-color);"> (not set)</small>
            #endif
          </label>
          <input
            type="password"
            id="openaiKey"
            name="openaiKey"
            placeholder="#if(hasOpenaiKey): #(openaiKey) #else: sk-... #endif"
            autocomplete="off"
          >

          <label for="deepseekKey">
            Deepseek API Key
            #if(hasDeepseekKey):
              <small style="color: var(--pico-ins-color);"> (configured)</small>
            #else:
              <small style="color: var(--pico-muted-color);"> (not set)</small>
            #endif
          </label>
          <input
            type="password"
            id="deepseekKey"
            name="deepseekKey"
            placeholder="#if(hasDeepseekKey): #(deepseekKey) #else: sk-... #endif"
            autocomplete="off"
          >

          <small style="color: var(--pico-muted-color);">
            Leave a field empty to keep the current key. Clear the field and submit to remove a key.
          </small>

          <button type="submit" style="margin-top: 1rem;">Save Keys</button>
        </form>
      </article>

      <article>
        <header><strong>Community</strong></header>
        <form method="post" action="/settings/config">
          <input type="hidden" name="contributeMemory" value="false">
          <label>
            <input
              type="checkbox"
              name="contributeMemory"
              value="true"
              #if(contributeMemory): checked #endif
            >
            Share working configs with the Cellar community
          </label>
          <small style="color: var(--pico-muted-color);">
            When enabled, successfully verified game configs are automatically shared to help other users.
          </small>

          <button type="submit" style="margin-top: 1rem;">Save</button>
        </form>
      </article>
    </section>
  #endexport
#endextend
